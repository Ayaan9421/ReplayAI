<Window x:Class="ValoAI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="Assets/ValoAI.ico"
        Title="ValoAI" Height="760" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <!-- Nav expand animation -->
        <Duration x:Key="NavDuration">0:0:0.22</Duration>
    </Window.Resources>

    <Border Background="{StaticResource BgBaseBrush}"
            CornerRadius="10" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="64"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ Title bar ══ -->
            <Border Grid.ColumnSpan="2"
                    Background="{StaticResource BgElevatedBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0">

                        <Image Source="Assets/ValoAI.png"
                            Width="20" Height="20"
                            Margin="0,0,8,0"/>
                        
                        <TextBlock Text="VALO"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Black" FontSize="15"
                                   />
                        <TextBlock Text="AI"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="Black" FontSize="15" />
                    </StackPanel>

                    <!-- Recording indicator -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="RecordingDot"
                                 Width="8" Height="8"
                                 Fill="#E84545"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="RecordingLabel"
                                   Text="Recording"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <Button Content="─" Style="{StaticResource GhostButton}"
                                Click="MinimizeButton_Click" FontSize="16"/>
                        <Button Content="✕" Style="{StaticResource GhostButton}"
                                Click="CloseButton_Click" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ Side nav ══ -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgElevatedBrush}"
                    x:Name="NavPanel"
                    MouseEnter="Nav_MouseEnter"
                    MouseLeave="Nav_MouseLeave">
                <StackPanel Margin="0,16,0,0">

                    <Button x:Name="NavDashboard"
                            Tag="Dashboard"
                            Click="NavButton_Click"
                            Style="{StaticResource GhostButton}"
                            Padding="0" Height="48">
                        <Grid Width="{Binding ActualWidth, ElementName=NavPanel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⬡" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="NavDashboardLabel"
                                       Text="Dashboard"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"
                                       Opacity="0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavClips"
                            Tag="Clips"
                            Click="NavButton_Click"
                            Style="{StaticResource GhostButton}"
                            Padding="0" Height="48">
                        <Grid Width="{Binding ActualWidth, ElementName=NavPanel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="▶" FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="NavClipsLabel"
                                       Text="Clips"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"
                                       Opacity="0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavSettings"
                            Tag="Settings"
                            Click="NavButton_Click"
                            Style="{StaticResource GhostButton}"
                            Padding="0" Height="48">
                        <Grid Width="{Binding ActualWidth, ElementName=NavPanel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚙" FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="NavSettingsLabel"
                                       Text="Settings"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"
                                       Opacity="0"/>
                        </Grid>
                    </Button>

                </StackPanel>
            </Border>

            <!-- ══ Main content area ══ -->
            <Frame Grid.Row="1" Grid.Column="1"
                   x:Name="ContentFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgBaseBrush}"/>

        </Grid>
        
    </Border>
</Window>
