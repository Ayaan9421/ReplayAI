<Page x:Class="ValoAI.App.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBaseBrush}"
      Title="Dashboard">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <!-- Greeting -->
            <TextBlock Text="Hey, Wraith693 👋"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Here's what's been happening."
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="14" Margin="0,0,0,32"/>

            <!-- Stats heading -->
            <TextBlock Text="STATS"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <!-- Stats cards row -->
            <UniformGrid Columns="4" Margin="0,0,0,40">
                <Border Background="{StaticResource BgSurfaceBrush}"
                        CornerRadius="8" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="CLIPS TODAY"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" FontWeight="SemiBold"/>
                        <TextBlock Text="—"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource BgSurfaceBrush}"
                        CornerRadius="8" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="TOTAL CLIPS"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="—"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource BgSurfaceBrush}"
                        CornerRadius="8" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="K/D RATIO"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="—"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock Text="tracker.gg coming soon"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource BgSurfaceBrush}"
                        CornerRadius="8" Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="WIN RATE"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="—"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock Text="tracker.gg coming soon"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent clips heading -->
            <TextBlock Text="RECENT CLIPS"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <!-- Clip cards — placeholder -->
            <UniformGrid x:Name="ClipGrid" Columns="4" Margin="0,0,0,16">
                <!-- Populated from code-behind -->
            </UniformGrid>

            <Button Content="View all clips →"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right"
                    Foreground="{StaticResource AccentBrush}"
                    FontSize="13"/>

        </StackPanel>
    </ScrollViewer>
</Page>