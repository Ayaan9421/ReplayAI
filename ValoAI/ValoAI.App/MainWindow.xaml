<Window x:Class="ValoAI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/Assets/ValoAI.ico"
        Title="ValoAI" Height="760" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border Background="{StaticResource BgBaseBrush}"
            CornerRadius="10" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ Title bar ══ -->
            <Border Grid.ColumnSpan="2"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0">
                        <Image Source="pack://application:,,,/Assets/ValoAI.png"
                               Width="18" Height="18"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,8,0"/>
                        <TextBlock Text="VALO"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Black" FontSize="14"/>
                        <TextBlock Text="AI"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="Black" FontSize="14"/>
                    </StackPanel>

                    <!-- Recording pill -->
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#18E84545"
                            BorderBrush="#30E84545"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="RecordingDot"
                                     Width="6" Height="6"
                                     Fill="#E84545"
                                     Margin="0,0,6,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.2" Duration="0:0:1"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock x:Name="RecordingLabel"
                                       Text="Recording"
                                       Foreground="#E84545"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <Button Content="─"
                                Style="{StaticResource IconButton}"
                                Click="MinimizeButton_Click"
                                FontSize="14"/>
                        <Button Content="✕"
                                Style="{StaticResource IconButton}"
                                Click="CloseButton_Click"
                                FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ Side nav ══ -->
            <Border Grid.Row="1"
                    x:Name="NavPanel"
                    Background="{StaticResource BgElevatedBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="0,0,1,0"
                    MouseEnter="Nav_MouseEnter"
                    MouseLeave="Nav_MouseLeave">
                <Grid>
                    <!-- Sliding amber indicator — positioned by code-behind -->
                    <Border x:Name="NavIndicator"
                            Width="3" Height="28"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="0,3,3,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="0,26,0,0"
                            RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="IndicatorTranslate"/>
                        </Border.RenderTransform>
                    </Border>

                    <StackPanel Margin="0,12,0,0">

                        <!-- Dashboard -->
                        <Button x:Name="NavDashboard"
                                Tag="Dashboard"
                                Click="NavButton_Click"
                                Style="{StaticResource GhostButton}"
                                Padding="0" Height="48">
                            <Grid Width="{Binding ActualWidth, ElementName=NavPanel}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⬡"
                                           x:Name="NavDashboardIcon"
                                           FontSize="17"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="NavDashboardLabel"
                                           Text="Dashboard"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" FontWeight="Medium"
                                           Opacity="0"/>
                            </Grid>
                        </Button>

                        <!-- Clips -->
                        <Button x:Name="NavClips"
                                Tag="Clips"
                                Click="NavButton_Click"
                                Style="{StaticResource GhostButton}"
                                Padding="0" Height="48">
                            <Grid Width="{Binding ActualWidth, ElementName=NavPanel}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="▶"
                                           x:Name="NavClipsIcon"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="NavClipsLabel"
                                           Text="Clips"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" FontWeight="Medium"
                                           Opacity="0"/>
                            </Grid>
                        </Button>

                        <!-- Settings -->
                        <Button x:Name="NavSettings"
                                Tag="Settings"
                                Click="NavButton_Click"
                                Style="{StaticResource GhostButton}"
                                Padding="0" Height="48">
                            <Grid Width="{Binding ActualWidth, ElementName=NavPanel}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚙"
                                           x:Name="NavSettingsIcon"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="NavSettingsLabel"
                                           Text="Settings"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13" FontWeight="Medium"
                                           Opacity="0"/>
                            </Grid>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ Content ══ -->
            <Frame Grid.Row="1" Grid.Column="1"
                   x:Name="ContentFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgBaseBrush}"/>
        </Grid>
    </Border>
</Window>