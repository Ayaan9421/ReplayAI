<Page x:Class="ValoAI.App.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:ValoAI.App.Controls"
      Background="{StaticResource BgBaseBrush}"
      Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,40" MaxWidth="640">

            <TextBlock Text="Settings"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Configure capture, hotkeys, and storage."
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="14" Margin="0,0,0,32"/>

            <!-- ══ Storage ══ -->
            <TextBlock Text="STORAGE"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Clips folder"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource BgElevatedBrush}"
                                CornerRadius="6" Padding="10,8">
                            <TextBlock x:Name="ClipsFolderText"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="1"
                                Content="Browse"
                                Style="{StaticResource AccentButton}"
                                Margin="8,0,0,0"
                                Click="BrowseFolder_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══ Capture ══ -->
            <TextBlock Text="CAPTURE"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>

                    <!-- Clip size -->
                    <TextBlock Text="Clip length"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ClipSizeCombo"
                              Margin="0,0,0,16">
                        <ComboBoxItem Content="30 seconds" Tag="30"/>
                        <ComboBoxItem Content="60 seconds" Tag="60"/>
                        <ComboBoxItem Content="90 seconds" Tag="90"/>
                        <ComboBoxItem Content="120 seconds" Tag="120"/>
                    </ComboBox>

                    <!-- FPS -->
                    <TextBlock Text="Frame rate"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <ComboBox x:Name="FpsCombo" Margin="0,0,0,16">
                        <ComboBoxItem Content="30 FPS" Tag="30"/>
                        <ComboBoxItem Content="60 FPS" Tag="60"/>
                        <ComboBoxItem Content="120 FPS" Tag="120"/>
                        <ComboBoxItem Content="144 FPS" Tag="144"/>
                    </ComboBox>

                    <!-- Resolution -->
                    <TextBlock Text="Resolution"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ResolutionCombo" Margin="0,0,0,16">
                        <ComboBoxItem Content="1280 x 720"  Tag="1280x720"/>
                        <ComboBoxItem Content="1920 x 1080" Tag="1920x1080"/>
                        <ComboBoxItem Content="2560 x 1440" Tag="2560x1440"/>
                        <ComboBoxItem Content="3840 x 2160" Tag="3840x2160"/>
                    </ComboBox>

                    <!-- Bitrate -->
                    <TextBlock Text="Bitrate"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="BitrateSlider"
                                Minimum="5" Maximum="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="BitrateSlider_ValueChanged"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="BitrateLabel"
                                   Text="20 Mbps"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Display -->
                    <TextBlock Text="Display"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <ComboBox x:Name="DisplayCombo" Margin="0,0,0,16"/>

                    <!-- Encoder -->
                    <TextBlock Text="Video encoder"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3">
                        <RadioButton x:Name="EncoderNvidia"
                                     Content="NVIDIA NVENC"
                                     GroupName="Encoder"
                                     IsChecked="True"
                                     Style="{StaticResource EncoderRadio}"/>
                        <RadioButton Content="AMD AMF (soon)"
                                     GroupName="Encoder"
                                     IsEnabled="False"
                                     Style="{StaticResource EncoderRadio}"/>
                        <RadioButton Content="Intel QSV (soon)"
                                     GroupName="Encoder"
                                     IsEnabled="False"
                                     Style="{StaticResource EncoderRadio}"/>
                    </UniformGrid>

                </StackPanel>
            </Border>

            <!-- ══ Hotkeys ══ -->
            <TextBlock Text="HOTKEYS"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Save clip"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <controls:HotkeyCapture x:Name="ClipHotkeyCapture" Margin="0,0,0,16"/>

                    <TextBlock Text="Push-to-talk"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <controls:HotkeyCapture x:Name="PTTHotkeyCapture" />
                </StackPanel>
            </Border>

            <!-- ══ Microphone ══ -->
            <TextBlock Text="MICROPHONE"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,32">
                <StackPanel>
                    <CheckBox x:Name="MicEnabledCheck"
                              Content="Record microphone"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="13"
                              IsChecked="True"
                              Margin="0,0,0,16"/>

                    <TextBlock Text="Input device"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
                    <ComboBox x:Name="MicDeviceCombo"/>
                </StackPanel>
            </Border>

            <!-- ══ Save ══ -->
            <DockPanel>
                <TextBlock x:Name="SaveStatusText"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Content="Save changes"
                        Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Right"
                        Padding="24,10"
                        Click="Save_Click"/>
            </DockPanel>

        </StackPanel>
    </ScrollViewer>
</Page>