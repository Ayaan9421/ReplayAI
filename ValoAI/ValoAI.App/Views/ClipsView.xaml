<Page x:Class="ValoAI.App.Views.ClipsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:ValoAI.App.Controls"
      Background="{StaticResource BgBaseBrush}"
      Title="Clips">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Top bar ── -->
        <Border Background="{StaticResource BgBaseBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="36,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Clips"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="ClipCountLabel"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Search -->
                <Grid Grid.Column="1" Width="280">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource SearchBox}"
                             Height="38"
                             TextChanged="Search_TextChanged"/>
                    <TextBlock Text="🔍  Search clips..."
                               x:Name="SearchPlaceholder"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="12,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Grid ── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="36,24,36,36">
            <Grid>
                <!-- Clip grid -->
                <WrapPanel x:Name="ClipGrid"
                           Orientation="Horizontal"/>

                <!-- Empty state -->
                <Border x:Name="EmptyState"
                        Padding="0,80"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="▶"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="40" Opacity="0.3"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock x:Name="EmptyLabel"
                                   Text="No clips yet"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Press Ctrl + Shift + F9 during gameplay to save a clip."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>