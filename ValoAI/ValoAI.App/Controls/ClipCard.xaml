<UserControl x:Class="ValoAI.App.Controls.ClipCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="Hand"
             MouseEnter="Card_MouseEnter"
             MouseLeave="Card_MouseLeave"
             MouseLeftButtonUp="Card_Click">

    <Border x:Name="CardBorder"
            Background="{StaticResource BgSurfaceBrush}"
            CornerRadius="8"
            ClipToBounds="True"
            Margin="0,0,12,12">

        <!-- Accent flash bar on left edge -->
        <Border.BorderBrush>
            <SolidColorBrush x:Name="BorderAccent" Color="#1E1E23"/>
        </Border.BorderBrush>
        <Border.BorderThickness>
            <Thickness Left="3"/>
        </Border.BorderThickness>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Thumbnail area -->
            <Border Background="#111114" CornerRadius="0">
                <Grid>
                    <!-- Thumbnail image (shown if exists) -->
                    <Image x:Name="Thumbnail"
                           Stretch="UniformToFill"
                           Opacity="0.85"/>

                    <!-- Placeholder (shown if no thumbnail) -->
                    <Border x:Name="Placeholder"
                            Background="#111114"
                            Visibility="Visible">
                        <TextBlock Text="▶"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"/>
                    </Border>

                    <!-- Hover overlay -->
                    <Border x:Name="HoverOverlay"
                            Background="#60000000"
                            Opacity="0">
                        <TextBlock Text="▶  PLAY"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Duration badge -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#CC000000"
                            CornerRadius="3"
                            Padding="5,2"
                            Margin="0,0,6,6">
                        <TextBlock x:Name="DurationText"
                                   Text="0:00"
                                   Foreground="White"
                                   FontSize="11"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Metadata -->
            <StackPanel Grid.Row="1" Margin="10,8,10,10">
                <TextBlock x:Name="DateText"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"/>
                <TextBlock x:Name="FileNameText"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12"
                           FontWeight="Medium"
                           Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>