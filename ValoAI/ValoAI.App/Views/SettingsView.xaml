<Page x:Class="ValoAI.App.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:ValoAI.App.Controls"
      Background="{StaticResource BgBaseBrush}"
      Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="36,32,36,48" MaxWidth="700">

            <TextBlock Text="Settings"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Configure capture, hotkeys, and audio."
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="13" Margin="0,0,0,32"/>

            <!-- ══ STORAGE ══ -->
            <TextBlock Text="STORAGE"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="9" FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,4" Margin="0,0,0,10">
                <StackPanel>
                    <!-- Row -->
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Clips folder"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Where clips are saved"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="10,8">
                                <TextBlock x:Name="ClipsFolderText"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Style="{StaticResource AccentButton}"
                                    Margin="8,0,0,0"
                                    Click="BrowseFolder_Click"/>
                        </Grid>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <!-- Run on startup -->
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Run on startup"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Launch when Windows starts"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <CheckBox x:Name="StartupCheck"
                                  Grid.Column="1"
                                  Content="Enabled"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══ CAPTURE ══ -->
            <TextBlock Text="CAPTURE"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="9" FontWeight="SemiBold"
                       Margin="0,16,0,10"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,4" Margin="0,0,0,10">
                <StackPanel>

                    <!-- Clip length -->
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Clip length"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Rolling buffer duration"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <ComboBox x:Name="ClipSizeCombo"
                                  Grid.Column="1" VerticalAlignment="Center">
                            <ComboBoxItem Content="30 seconds" Tag="30"/>
                            <ComboBoxItem Content="60 seconds" Tag="60"/>
                            <ComboBoxItem Content="90 seconds" Tag="90"/>
                            <ComboBoxItem Content="120 seconds" Tag="120"/>
                        </ComboBox>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <!-- Frame rate -->
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Frame rate"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Match your monitor refresh"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <ComboBox x:Name="FpsCombo"
                                  Grid.Column="1" VerticalAlignment="Center">
                            <ComboBoxItem Content="30 FPS"  Tag="30"/>
                            <ComboBoxItem Content="60 FPS"  Tag="60"/>
                            <ComboBoxItem Content="120 FPS" Tag="120"/>
                            <ComboBoxItem Content="144 FPS" Tag="144"/>
                        </ComboBox>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <!-- Resolution -->
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Resolution"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Capture output size"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <ComboBox x:Name="ResolutionCombo"
                                  Grid.Column="1" VerticalAlignment="Center">
                            <ComboBoxItem Content="1280 × 720"  Tag="1280x720"/>
                            <ComboBoxItem Content="1920 × 1080" Tag="1920x1080"/>
                            <ComboBoxItem Content="2560 × 1440" Tag="2560x1440"/>
                            <ComboBoxItem Content="3840 × 2160" Tag="3840x2160"/>
                        </ComboBox>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <!-- Bitrate -->
                    <Grid Height="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Bitrate"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Video quality"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <Slider x:Name="BitrateSlider"
                                Grid.Column="1"
                                Minimum="5" Maximum="50"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0"
                                ValueChanged="BitrateSlider_ValueChanged"/>
                        <TextBlock x:Name="BitrateLabel"
                                   Grid.Column="2"
                                   Text="20 Mbps"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <!-- Display -->
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Display"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Screen to capture"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <ComboBox x:Name="DisplayCombo"
                                  Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <!-- Encoder -->
                    <Grid Height="68">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Video encoder"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="GPU hardware encoder"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <UniformGrid Grid.Column="1" Columns="3"
                                     VerticalAlignment="Center">
                            <RadioButton x:Name="EncoderNvidia"
                                         Content="NVIDIA NVENC"
                                         GroupName="Encoder"
                                         IsChecked="True"
                                         Style="{StaticResource EncoderRadio}"/>
                            <RadioButton Content="AMD AMF"
                                         GroupName="Encoder"
                                         IsEnabled="False"
                                         Style="{StaticResource EncoderRadio}"/>
                            <RadioButton Content="Intel QSV"
                                         GroupName="Encoder"
                                         IsEnabled="False"
                                         Style="{StaticResource EncoderRadio}"/>
                        </UniformGrid>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ══ HOTKEYS ══ -->
            <TextBlock Text="HOTKEYS"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="9" FontWeight="SemiBold"
                       Margin="0,16,0,10"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,4" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Save clip"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Click to rebind"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <controls:HotkeyCapture x:Name="ClipHotkeyCapture"
                                                Grid.Column="1"
                                                VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Push-to-talk"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Hold to record mic"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <controls:HotkeyCapture x:Name="PTTHotkeyCapture"
                                                Grid.Column="1"
                                                VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══ MICROPHONE ══ -->
            <TextBlock Text="MICROPHONE"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="9" FontWeight="SemiBold"
                       Margin="0,16,0,10"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="20,4" Margin="0,0,0,32">
                <StackPanel>
                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Record mic"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Capture push-to-talk audio"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <CheckBox x:Name="MicEnabledCheck"
                                  Grid.Column="1"
                                  Content="Enabled"
                                  IsChecked="True"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource SeparatorBrush}"/>

                    <Grid Height="52">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Input device"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Microphone to record from"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <ComboBox x:Name="MicDeviceCombo"
                                  Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ══ Save ══ -->
            <DockPanel>
                <TextBlock x:Name="SaveStatusText"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <Button Content="Save &amp; Restart"
                        Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Right"
                        Padding="20,10"
                        Click="Save_Click"/>
            </DockPanel>

        </StackPanel>
    </ScrollViewer>
</Page>